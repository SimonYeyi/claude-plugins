{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "plugin:bug-book:bug-book",
            "tool": "recall_for_hook",
            "input": {
              "file_path": "${tool_input.file_path}",
              "transcript_path": "${event.transcript_path}",
              "limit": 10
            },
            "additionalContext": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "(?:git\\s+)?mv\\s+.+",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "plugin:bug-book:bug-book",
            "tool": "migrate_path_for_hook",
            "input": {
              "command": "${tool_input.command}"
            },
            "additionalContext": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/organize_reminder.py\"",
            "timeout": 1000
          }
        ]
      }
    ]
  }
}
